{
  "name": "iron-ashes",
  "version": "0.1.0",
  "description": "Iron Throne of Ashes — Alliance Engine v1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc",
    "start:server": "cd server && npm start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:v2": "vitest run tests/v2",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "verify:check": "node scripts/verify.mjs --check",
    "handoff:check": "node scripts/handoff-check.mjs"
  },
  "keywords": [
    "board-game",
    "alliance-engine",
    "gll"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.1",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "10.2.4"
  }
}