{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "../",
        "baseUrl": ".",
        "paths": {
            "~/*": [
                "../src/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../src/models/**/*",
        "../src/engine/**/*",
        "../src/systems/**/*",
        "../src/utils/**/*"
    ],
    "exclude": [
        "node_modules",
        "../node_modules"
    ]
}